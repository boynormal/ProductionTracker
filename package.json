{
  "name": "production-tracker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\"",
    "dev": "next dev -H 0.0.0.0",
    "dev:clean": "npm run clean && npm run dev",
    "build": "next build",
    "verify": "npx tsc --noEmit && npm run build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node -P tsconfig.seed.json prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "db:clear-production": "ts-node -P tsconfig.seed.json prisma/clear-production-data.ts",
    "db:import": "ts-node -P tsconfig.seed.json prisma/import-cap.ts",
    "db:import-sections": "ts-node -P tsconfig.seed.json prisma/import-sections.ts",
    "db:import-employees": "ts-node -P tsconfig.seed.json prisma/import-employees.ts",
    "db:cleanup-cap-imp": "ts-node -P tsconfig.seed.json prisma/cleanup-cap-imp.ts",
    "db:seed-permissions": "ts-node -P tsconfig.seed.json prisma/seed-permissions.ts",
    "verify:permissions": "ts-node -P tsconfig.seed.json prisma/verify-permissions.ts",
    "telegram:ping": "node --env-file=.env.local scripts/telegram-ping.mjs"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.15",
    "@fullcalendar/daygrid": "^6.1.15",
    "@fullcalendar/interaction": "^6.1.15",
    "@fullcalendar/react": "^6.1.15",
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jose": "^6.2.2",
    "lucide-react": "^0.469.0",
    "next": "15.5.14",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.4",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.66.0",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^18",
    "react-day-picker": "^9.4.4",
    "react-dom": "^18",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.0",
    "sharp": "^0.34.5",
    "sonner": "^1.7.1",
    "swr": "^2.3.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.7",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "15.5.14",
    "postcss": "^8",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "xlsx": "^0.18.5"
  }
}
